################################################################################
# ROUTER API v2 - ENV EXAMPLE
################################################################################

# ===== SERVER =====
ROUTER_API_HOST=127.0.0.1
ROUTER_API_PORT=58100
ROUTER_API_AUTH_TOKEN=

# ===== ACCOUNTS =====
ROUTER_API_ACCOUNTS_FILE=accounts.json
ROUTER_API_DEFAULT_ACCOUNT_RPM=30
ROUTER_API_DEFAULT_ACCOUNT_TPM=200000
ROUTER_API_DEFAULT_ACCOUNT_RPD=1000

# ===== GEMINI KEYS (auto-detected: GEMINI_API_KEY_1..N) =====
# Warning: 101 keys but all in same project → project quota (~5 RPM) is the bottleneck
GEMINI_API_KEY_1=your_gemini_key_1
GEMINI_API_KEY_2=

# ===== MODEL ALIASES =====
GEMINI_FLASH_35_MODEL=gemini-3.5-flash
GEMINI_FLASH_30_MODEL=gemini-3-flash-preview
GEMINI_FLASH_LITE_MODEL=gemini-3.1-flash-lite
GEMINI_FLASH_25_MODEL=gemini-2.5-flash
GEMINI_FLASH_25_LITE_MODEL=gemini-2.5-flash-lite
ROUTER_API_DEFAULT_MODEL_ALIAS=gemini-flash-35

# ===== GENERATION / RETRY =====
ROUTER_API_REQUEST_TIMEOUT_SEC=120
ROUTER_API_MAX_OUTPUT_TOKENS=8192
ROUTER_API_MAX_RETRIES=3
POOL_SWAP_FAILURES=2
POOL_MAX_ATTEMPTS=6

# ===== GEMINI RATE LIMITS =====
# RPM thấp vì project quota ~5 RPM regardless of key count
GEMINI_FLASH_35_RPM=5
GEMINI_FLASH_35_TPM=250000
GEMINI_FLASH_35_RPD=20
GEMINI_FLASH_30_RPM=5
GEMINI_FLASH_30_TPM=250000
GEMINI_FLASH_30_RPD=20
GEMINI_FLASH_LITE_RPM=15
GEMINI_FLASH_LITE_TPM=250000
GEMINI_FLASH_LITE_RPD=500
GEMINI_FLASH_25_RPM=5
GEMINI_FLASH_25_TPM=250000
GEMINI_FLASH_25_RPD=20
GEMINI_FLASH_25_LITE_RPM=3
GEMINI_FLASH_25_LITE_TPM=250000
GEMINI_FLASH_25_LITE_RPD=20

# ===== KEY COOLDOWN =====
KEY_429_COOLDOWN_SECONDS=15
KEY_INVALID_COOLDOWN_SECONDS=3600
KEY_UNKNOWN_ERROR_COOLDOWN_SECONDS=30

# ===== PER-KEY THROTTLE (gemini_api_manager) =====
GEMINI_API_GLOBAL_INTERVAL=6
GEMINI_API_KEY_INTERVAL=5
GEMINI_API_MAX_CONCURRENT=0
GEMINI_GLOBAL_COOLDOWN_SEC=5
GEMINI_PROJECT_FREEZE_SEC=60
GEMINI_UNAVAILABLE_DELAY_SEC=50

# ===== CIRCUIT BREAKER =====
ROUTER_API_CIRCUIT_ENABLED=true
ROUTER_API_CIRCUIT_FAILURE_THRESHOLD=10
ROUTER_API_CIRCUIT_WINDOW_SECONDS=30
ROUTER_API_CIRCUIT_OPEN_SECONDS=60

# ===== OPTIONAL RELAY / PROXY =====
GEMINI_PROXY_ENABLED=false
GEMINI_RELAY_URL=
GEMINI_RELAY_SECRET=
GEMINI_PROXY_FALLBACK_DIRECT=true
GEMINI_RELAY_TIMEOUT=60
